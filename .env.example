# =============================================================================
# Bybit AI Trader — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env with real secrets to version control.
# All secrets should be injected via environment variables or Docker secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# SECTION 1: Trading Mode & Safety
# -----------------------------------------------------------------------------

# Trading execution mode. Options: TESTNET | SHADOW | CANARY_LIVE | LIVE
# SHADOW uses mainnet data but never submits orders — recommended for cloud
# deployments (Render, AWS) where Bybit testnet blocks by IP.
# NEVER change to LIVE without reading RUNBOOK.md first.
TRADING_MODE=SHADOW

# Risk appetite profile. Options: CONSERVATIVE | MODERATE | AGGRESSIVE | SCALP
RISK_PROFILE=CONSERVATIVE

# Explicit live-mode opt-in. Must be set to true to allow TRADING_MODE=LIVE.
# This is a deliberate double-gate: both TRADING_MODE and LIVE_MODE must agree.
LIVE_MODE=false

# Shadow mode: compute signals but never submit orders (paper trading on live data).
SHADOW_MODE=true

# -----------------------------------------------------------------------------
# SECTION 2: Bybit API Credentials
# -----------------------------------------------------------------------------

# Bybit API key. Generate from https://www.bybit.com/app/user/api-management
# Use TESTNET keys for development: https://testnet.bybit.com/
BYBIT_API_KEY=CHANGE_ME

# Bybit API secret corresponding to the above key.
BYBIT_API_SECRET=CHANGE_ME

# Regional entity. Options: GLOBAL | NL | EEA | TR | KZ | GE | AE | ID
BYBIT_REGION=GLOBAL

# Whether to connect to the Bybit testnet (true) or mainnet (false).
# MUST be true when TRADING_MODE=TESTNET.
# For TRADING_MODE=SHADOW you may set this to false to use mainnet endpoints —
# safe because orders are never submitted in shadow mode.  Use false when your
# host (e.g. Render, AWS) is blocked by Bybit testnet's US-IP restriction.
BYBIT_USE_TESTNET=false

# Set false on hosts where Bybit blocks the datacenter IP, e.g. some free hosts.
BYBIT_CONNECTIVITY_REQUIRED=false

# Default Bybit market category used by read-only monitoring commands.
# Options: linear | spot | inverse | option
DEFAULT_MARKET_CATEGORY=linear

# -----------------------------------------------------------------------------
# SECTION 3: Database — PostgreSQL
# -----------------------------------------------------------------------------

# PostgreSQL async connection string. Use Supabase or another external database
# for the default docker-compose.mini.yml startup.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_DSN=postgresql+asyncpg://trader:CHANGE_ME@postgres:5432/trader

# Persist signals, risk decisions, order events, and closed PnL in Postgres/Supabase.
TRADE_JOURNAL_ENABLED=true

# Use recent closed PnL to skip symbols that are losing repeatedly.
PERFORMANCE_FILTER_ENABLED=true
PERFORMANCE_MIN_CLOSED_TRADES=5
PERFORMANCE_MAX_SYMBOL_LOSS_USD=-2.0
PERFORMANCE_LOOKBACK_DAYS=7
PERFORMANCE_MIN_TRADABLE_SYMBOLS=2
CLOSED_PNL_REFRESH_INTERVAL_SECONDS=300

# Move profitable positions to breakeven and enable Bybit trailing stop.
PROFIT_MANAGER_ENABLED=true
TRAILING_STOP_ENABLED=true
POSITION_MANAGEMENT_INTERVAL_SECONDS=30
TRAILING_ACTIVATION_PCT=0.70
TRAILING_DISTANCE_PCT=0.25
BREAKEVEN_STOP_OFFSET_PCT=0.20

# Only needed when using docker-compose.mini.yml with --profile local-db.
# Must match the password embedded in POSTGRES_DSN when using local Docker Postgres.
POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# SECTION 3b: Execution Safety
# -----------------------------------------------------------------------------

# Entry order mode. Only MARKET is production-ready. POST_ONLY_LIMIT is blocked.
ENTRY_ORDER_MODE=MARKET

# Expected round-trip slippage per side (%). Used in net-edge calculation.
# Net edge uses 2× this value to account for both entry and exit slippage.
EXPECTED_SLIPPAGE_PCT=0.03

# Minimum expected net edge required to open a new entry (%).
# Orders with expected net edge below this threshold are rejected.
MIN_EXPECTED_NET_EDGE_PCT=0.15

# Minimum net profit buffer above break-even required (%).
MIN_NET_PROFIT_BUFFER_PCT=0.08

# Estimated funding-rate buffer per holding period (%).
FUNDING_BUFFER_PCT=0.01

# How often to sync Bybit account transaction log (seconds).
TRANSACTION_LOG_SYNC_INTERVAL_SECONDS=60

# How long before a pending entry order is considered stale and cleared (seconds).
STALE_PENDING_TTL_SECONDS=600

# -----------------------------------------------------------------------------
# SECTION 4: Cache — Redis
# -----------------------------------------------------------------------------

# Redis connection URL. Optional for Render Free monitoring mode.
REDIS_URL=
REDIS_REQUIRED=false

# -----------------------------------------------------------------------------
# SECTION 5: Telegram Notifications
# -----------------------------------------------------------------------------

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Comma-separated list of chat IDs allowed to receive notifications.
# Find your chat ID by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_CHAT_IDS=CHANGE_ME

# -----------------------------------------------------------------------------
# SECTION 6: LLM Integration (optional, disabled by default)
# -----------------------------------------------------------------------------

# Enable LLM-assisted analysis (experimental). Default: false.
# The LLM CANNOT directly submit orders; it only provides analysis.
LLM_ENABLED=false

# LLM provider. Options: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Base URL for the LLM API.
LLM_BASE_URL=http://ollama:11434

# Model name.
LLM_MODEL=llama3

# Maximum daily USD spend on external LLM API calls.
LLM_BUDGET_CAP_USD=5.0

# API key for external LLM providers (leave blank for Ollama).
LLM_API_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# SECTION 7: Risk Parameters
# -----------------------------------------------------------------------------

# Maximum number of concurrent open positions.
MAX_POSITIONS=2

# Maximum single position size as % of equity.
MAX_POSITION_SIZE_PCT=1.0

# Maximum total portfolio heat (sum of all position risks) as % of equity.
MAX_PORTFOLIO_HEAT_PCT=3.0

# Daily drawdown circuit breaker (% of equity). Triggers SAFE_MODE.
MAX_DAILY_DRAWDOWN_PCT=2.0

# Weekly drawdown circuit breaker (% of equity). Triggers KILL_SWITCH.
MAX_WEEKLY_DRAWDOWN_PCT=5.0

# -----------------------------------------------------------------------------
# SECTION 8: Observability & Monitoring
# -----------------------------------------------------------------------------

# Port for the Prometheus metrics endpoint.
PROMETHEUS_PORT=9090

# Port for the FastAPI observability API.
FASTAPI_PORT=8080

# Log level. Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format. Options: json (production) | console (development)
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# SECTION 9: Operational Timings
# -----------------------------------------------------------------------------

# How often to run the reconciliation loop (seconds).
RECONCILIATION_INTERVAL_SECONDS=30

# How often to sync Bybit positions after TP/SL closes them.
POSITION_SYNC_INTERVAL_SECONDS=30

# How often to run health checks (seconds).
HEALTH_CHECK_INTERVAL_SECONDS=15

# Maximum age of market data before it is considered stale (seconds).
DATA_STALENESS_THRESHOLD_SECONDS=5

# Maximum age of feature vectors before re-computation is forced (seconds).
FEATURE_STALENESS_THRESHOLD_SECONDS=10

# Maximum age of model inference before model is flagged as stale (seconds).
MODEL_STALENESS_THRESHOLD_SECONDS=3600

# -----------------------------------------------------------------------------
# SECTION 10: MLflow (optional)
# -----------------------------------------------------------------------------

# MLflow tracking server URI.
MLFLOW_TRACKING_URI=http://mlflow:5000

# MLflow experiment name.
MLFLOW_EXPERIMENT_NAME=bybit-trader-phase1

# -----------------------------------------------------------------------------
# SECTION 11: Market Screener (multi-tier universe)
# -----------------------------------------------------------------------------

# Maximum symbols passing volume+spread+depth filters (wide universe).
SCREENER_WIDE_MAX_SYMBOLS=80

# Symbols receiving WS subscriptions + feature computation (feature universe).
SCREENER_FEATURE_MAX_SYMBOLS=30

# Top symbols evaluated by strategy each cycle (execution candidates).
SCREENER_EXECUTION_CANDIDATES=15

# Minimum 24h turnover in USD to enter the wide universe.
SCREENER_MIN_VOLUME_USD=20000000

# Maximum bid-ask spread in basis points (wider → excluded).
SCREENER_MAX_SPREAD_BPS=8.0

# Minimum top-of-book depth in USD (bid1Size*bid1Price + ask1Size*ask1Price).
SCREENER_MIN_TOP_BOOK_DEPTH_USD=5000.0

# How often to refresh the screener universe (seconds).
SCREENER_REFRESH_SECONDS=900

# Timeout for WS subscribe acknowledgement per symbol (seconds).
SCREENER_SUBSCRIBE_TIMEOUT_SECONDS=10

# Comma-separated denylist of symbols (pre-market, innovation zone, etc.).
# SCREENER_DENYLIST=[]
