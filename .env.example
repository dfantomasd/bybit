# =============================================================================
# Bybit AI Trader — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env with real secrets to version control.
# All secrets should be injected via environment variables or Docker secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# SECTION 1: Trading Mode & Safety
# -----------------------------------------------------------------------------

# Trading execution mode. Options: TESTNET | SHADOW | CANARY_LIVE | LIVE
# SHADOW uses mainnet data but never submits orders — recommended while auditing.
TRADING_MODE=SHADOW

# Risk appetite profile. Options: CONSERVATIVE | MODERATE | AGGRESSIVE | SCALP
RISK_PROFILE=CONSERVATIVE

# Real-order double gate. Keep both false outside an explicitly approved rollout.
LIVE_MODE=false
LIVE_ARMED=false

# Compute signals but never submit orders.
SHADOW_MODE=true

# Telegram must not increase the risk profile unless explicitly enabled.
TELEGRAM_ALLOW_RISK_INCREASE=false

# -----------------------------------------------------------------------------
# SECTION 2: Bybit API Credentials
# -----------------------------------------------------------------------------

BYBIT_API_KEY=CHANGE_ME
BYBIT_API_SECRET=CHANGE_ME

# Regional entity. Options: GLOBAL | NL | EEA | TR | KZ | GE | AE | ID
BYBIT_REGION=GLOBAL

# TESTNET requires true. SHADOW may use false to read mainnet market data safely.
BYBIT_USE_TESTNET=false
BYBIT_CONNECTIVITY_REQUIRED=false
DEFAULT_MARKET_CATEGORY=linear

# -----------------------------------------------------------------------------
# SECTION 3: Database — PostgreSQL
# -----------------------------------------------------------------------------

# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_DSN=postgresql+asyncpg://trader:CHANGE_ME@postgres:5432/trader
TRADE_JOURNAL_ENABLED=true

# Block real entries if the durable journal is unavailable.
TRADE_JOURNAL_REQUIRED_FOR_ACTIVE=true
DURABLE_ORDER_STATE_REQUIRED_FOR_ACTIVE=true

# Skip symbols that repeatedly lose money.
PERFORMANCE_FILTER_ENABLED=true
PERFORMANCE_MIN_CLOSED_TRADES=5
PERFORMANCE_MAX_SYMBOL_LOSS_USD=-2.0
PERFORMANCE_LOOKBACK_DAYS=7
PERFORMANCE_MIN_TRADABLE_SYMBOLS=2
CLOSED_PNL_REFRESH_INTERVAL_SECONDS=300

# Profit management.
PROFIT_MANAGER_ENABLED=true
TRAILING_STOP_ENABLED=true
POSITION_MANAGEMENT_INTERVAL_SECONDS=30
TRAILING_ACTIVATION_PCT=0.70
TRAILING_DISTANCE_PCT=0.25
BREAKEVEN_STOP_OFFSET_PCT=0.20
MIN_NET_PROFIT_BUFFER_PCT=0.08

# Execution cost assumptions.
EXPECTED_SLIPPAGE_PCT=0.03
DEFAULT_LINEAR_MAKER_FEE_RATE=0.0002
DEFAULT_LINEAR_TAKER_FEE_RATE=0.00055
MIN_EXPECTED_NET_EDGE_PCT=0.25
NET_EDGE_SAFETY_MARGIN_PCT=0.05
FUNDING_BUFFER_PCT=0.01

# Only MARKET and MAKER_FIRST are implemented during the current safety rollout.
ENTRY_ORDER_MODE=MARKET

# -----------------------------------------------------------------------------
# SECTION 4: Cache — Redis
# -----------------------------------------------------------------------------

REDIS_URL=
REDIS_REQUIRED=false

# -----------------------------------------------------------------------------
# SECTION 5: Telegram Notifications
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALLOWED_CHAT_IDS=CHANGE_ME

# -----------------------------------------------------------------------------
# SECTION 6: LLM Integration (optional, disabled by default)
# -----------------------------------------------------------------------------

LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3
LLM_BUDGET_CAP_USD=5.0

# -----------------------------------------------------------------------------
# SECTION 7: Risk Parameters
# -----------------------------------------------------------------------------

MAX_POSITIONS=2
MAX_POSITION_SIZE_PCT=1.0
MAX_PORTFOLIO_HEAT_PCT=3.0
MAX_DAILY_DRAWDOWN_PCT=2.0
MAX_WEEKLY_DRAWDOWN_PCT=5.0

# Burst guards.
MAX_NEW_ENTRIES_PER_MINUTE=1
MAX_CONCURRENT_PENDING_ENTRIES=1
MAX_SAME_SIDE_POSITIONS=2
MAX_CORRELATED_POSITIONS=2
STARTUP_WARMUP_SECONDS=180

# -----------------------------------------------------------------------------
# SECTION 8: Observability & Monitoring
# -----------------------------------------------------------------------------

PROMETHEUS_PORT=9090
FASTAPI_PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# SECTION 9: Operational Timings
# -----------------------------------------------------------------------------

RECONCILIATION_INTERVAL_SECONDS=30
POSITION_SYNC_INTERVAL_SECONDS=30
TRANSACTION_LOG_SYNC_INTERVAL_SECONDS=60
HEALTH_CHECK_INTERVAL_SECONDS=15
DATA_STALENESS_THRESHOLD_SECONDS=5
FEATURE_STALENESS_THRESHOLD_SECONDS=10
MODEL_STALENESS_THRESHOLD_SECONDS=3600

# -----------------------------------------------------------------------------
# SECTION 10: ML Auto-promotion (disabled by default — requires explicit opt-in)
# -----------------------------------------------------------------------------
MODEL_AUTO_PROMOTE_ENABLED=false
MODEL_AUTO_PROMOTE_CHECK_SECONDS=600
MODEL_AUTO_PROMOTE_MIN_SIGNALS=50
MODEL_AUTO_PROMOTE_MIN_LIFT_BPS=1.0
MODEL_AUTO_PROMOTE_MIN_PASS_EXPECTANCY_BPS=0.0
MODEL_AUTO_PROMOTE_MIN_WF_BPS=0.0
MODEL_AUTO_PROMOTE_MIN_WF_POSITIVE_FOLDS=3
MODEL_AUTO_PROMOTE_MAX_WF_STD_BPS=25.0
MODEL_CHAMPION_MONITOR_SECONDS=14400
MODEL_CHAMPION_MIN_WF_BPS=0.0
MODEL_CHAMPION_MAX_DRAWDOWN_BPS=1500.0
MODEL_CHAMPION_MIN_PAPER_GATE_COUNT=50

# -----------------------------------------------------------------------------
# SECTION 11: Market Screener (multi-tier universe)
# -----------------------------------------------------------------------------

SCREENER_WIDE_MAX_SYMBOLS=80
SCREENER_FEATURE_MAX_SYMBOLS=30
SCREENER_EXECUTION_CANDIDATES=15
SCREENER_MIN_VOLUME_USD=20000000
SCREENER_MAX_SPREAD_BPS=8.0
SCREENER_MIN_TOP_BOOK_DEPTH_USD=5000.0
SCREENER_REFRESH_SECONDS=900
SCREENER_SUBSCRIBE_TIMEOUT_SECONDS=10
# SCREENER_DENYLIST=[]

# -----------------------------------------------------------------------------
# SECTION 12: ML Shadow Training
# -----------------------------------------------------------------------------

# Collect labels and train challengers. Models cannot affect real entries yet.
MODEL_ENABLED=false
# Challenger architecture. GBDT is stronger for feature interactions; LOGREG is
# a regularized sanity baseline; SGD keeps online partial_fit support for legacy runs.
MODEL_TYPE=GBDT
MODEL_CANDIDATES=GBDT,LOGREG
MODEL_WF_FOLDS=5
MODEL_WF_MIN_TRAIN_SAMPLES=500
MODEL_LABEL_HORIZON=30
MODEL_THRESHOLD_GRID=0,2,5,8,12
MODEL_MIN_PASS_COUNT_FOR_PROMOTION=20
TRAIN_EXCLUDE_NEGATIVE_BUCKETS=false
TRAIN_MIN_BUCKET_SAMPLES=50
TRAIN_BUCKET_MIN_AVG_BPS=-5.0
MODEL_ALLOW_LIVE_DECISIONS=false
MODEL_SHADOW_SCORING_ENABLED=true
MODEL_SHADOW_GATE_ENABLED=true
MODEL_SHADOW_GATE_THRESHOLD=0.55

# Automatic training is allowed. Automatic promotion is intentionally disabled
# until Challenger shadow scoring and Champion-only Canary decisions are split
# explicitly inside the runtime loop.
MODEL_AUTO_TRAIN_ENABLED=true
MODEL_AUTO_TRAIN_MIN_SAMPLES=1000
MODEL_AUTO_TRAIN_INCREMENT_SAMPLES=1000
MODEL_AUTO_TRAIN_CHECK_SECONDS=300
MODEL_AUTO_TRAIN_HORIZON_MINUTES=15
MODEL_AUTO_TRAIN_LABEL_BPS=5.0

# Canary model gate must remain off during the current recalibration period.
MODEL_GATE_CANARY_ENABLED=false
MODEL_GATE_CANARY_MIN_QUALITY=GOOD
MODEL_GATE_CANARY_MAX_BLOCK_RATE_PCT=60
MODEL_GATE_CANARY_MIN_OBSERVATIONS=50
MODEL_GATE_CANARY_MIN_LIFT_BPS=0.0
MODEL_GATE_CANARY_ALLOW_EVERY_NTH_BLOCKED=3
MODEL_PAPER_NOTIONAL_USD=5.0

# Encryption key for model artifacts stored in the database.
# Set to any long random string (e.g. openssl rand -base64 32).
# Without this key the artifact is saved unencrypted (SHADOW mode only; warning logged).
MODEL_ENCRYPT_KEY=
# =============================================================================
# SECTION: Advanced / Tuning (safe defaults shown — change only when needed)
# =============================================================================

# -----------------------------------------------------------------------------
# Screener price filters
# -----------------------------------------------------------------------------
# 0 = disabled. Render Starter sets max to 25.0 automatically via STARTER_OPTIMIZED_MODE.
SCREENER_MIN_PRICE_USD=0.0
SCREENER_MAX_PRICE_USD=0.0

# Memory/CPU conservative mode for Render Starter plan
STARTER_OPTIMIZED_MODE=true

# -----------------------------------------------------------------------------
# Scalping strategy
# -----------------------------------------------------------------------------
SCALP_STRATEGY_ENABLED=true
MAX_SPREAD_BPS_SCALP=2.5
MIN_NET_SCALP_RETURN_PCT=0.08
SCALP_COOLDOWN_SECONDS=60
SCALP_MAX_TRADES_PER_MINUTE=10
SCALP_MAX_POSITION_NOTIONAL_USD=100.0
SCALP_MIN_OB_IMBALANCE=0.15
TREND_MIN_ADX=0.25
TREND_BLOCK_NEGATIVE_FUNDING_OI=true

# -----------------------------------------------------------------------------
# Orderbook feed
# -----------------------------------------------------------------------------
ORDERBOOK_FEED_ENABLED=true
ORDERBOOK_MODE=ON_DEMAND
MAX_ORDERBOOK_ACTIVE_SYMBOLS=5

# -----------------------------------------------------------------------------
# Per-candle training sampler
# -----------------------------------------------------------------------------
CANDLE_SAMPLING_ENABLED=true

# -----------------------------------------------------------------------------
# Regime-bucket performance gating
# -----------------------------------------------------------------------------
BUCKET_BLOCK_ENABLED=true
BUCKET_MIN_SAMPLES=30
BUCKET_BLOCK_AVG_BPS=-2.0
BUCKET_STATS_REFRESH_SECONDS=3600

# -----------------------------------------------------------------------------
# Startup candle backfill
# -----------------------------------------------------------------------------
STARTUP_BACKFILL_ENABLED=true
STARTUP_BACKFILL_DAYS=2
STARTUP_BACKFILL_MAX_REQUESTS=200

# -----------------------------------------------------------------------------
# Anti zero-trading guards
# -----------------------------------------------------------------------------
MIN_SIGNALS_PER_HOUR=1
AUTO_SOFTEN_FILTERS_ENABLED=false
FALLBACK_TO_RULE_WHEN_MODEL_UNSURE=true

# -----------------------------------------------------------------------------
# Maker-first execution
# -----------------------------------------------------------------------------
MAKER_TIMEOUT_SECONDS=3.0
MAKER_TTL_SECONDS=5.0
MAKER_ALLOW_ESCALATION=true

# -----------------------------------------------------------------------------
# Multi-timeframe candle store
# -----------------------------------------------------------------------------
MULTITIMEFRAME_ENABLED=true
MULTITIMEFRAME_INTERVALS=["1","5","15","60"]
CANDLE_STORE_MAX_BARS_1M=250
CANDLE_STORE_MAX_BARS_5M=250
CANDLE_STORE_MAX_BARS_15M=200
CANDLE_STORE_MAX_BARS_1H=120

# -----------------------------------------------------------------------------
# Adaptive load governor
# -----------------------------------------------------------------------------
ADAPTIVE_LOAD_GOVERNOR_ENABLED=true
LOAD_GOVERNOR_CHECK_SECONDS=30
MAX_FEATURE_CYCLE_MS=8000
MAX_STRATEGY_CYCLE_MS=8000
MAX_EVENT_LOOP_LAG_MS=500
MAX_QUEUE_UTILIZATION_PCT=70
LOAD_GOVERNOR_MIN_FEATURE_SYMBOLS=10
LOAD_GOVERNOR_MIN_EXECUTION_CANDIDATES=3

# -----------------------------------------------------------------------------
# CANARY_LIVE safety limits
# -----------------------------------------------------------------------------
CANARY_MAX_OPEN_POSITIONS=2
CANARY_MAX_TOTAL_EXPOSURE_PCT=45.0

# -----------------------------------------------------------------------------
# ML model training & promotion
# -----------------------------------------------------------------------------
MODEL_MIN_TRAINING_SAMPLES=500
MODEL_MIN_CLOSED_TRADES_FOR_PROMOTION=50
MODEL_AUTO_PROMOTE_PVALUE_THRESHOLD=0.05
MODEL_AUTO_PROMOTE_BOOTSTRAP_ITERATIONS=1000
MODEL_AUTO_PROMOTE_MIN_BOOTSTRAP_SAMPLES=50

# -----------------------------------------------------------------------------
# Safety / notional
# -----------------------------------------------------------------------------
MIN_NOTIONAL_SAFETY_BUFFER_PCT=3.0
